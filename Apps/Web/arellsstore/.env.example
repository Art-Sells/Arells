# Existing
S3_BUCKET_NAME=

# Auth (required for login / session cookies; min 16 characters)
AUTH_JWT_SECRET=

# Transactional email (AWS SES). Required for sending; optional while testing:
# AUTH_EMAIL_DISABLED=1 logs the verification/reset URL instead of sending.
VERIFY_EMAIL_FROM=verifyemail@arells.com
PASSWORD_RESET_FROM=resetpassword@arells.com
# Optional: override logo URL in auth emails (default is https://arells.com/ArellsIcoIcon.png)
# AUTH_EMAIL_LOGO_URL=https://example.com/logo.png
# AUTH_EMAIL_DISABLED=1

# Fallback when Origin header is missing (e.g. some server-side calls)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to 1 on Amplify temporarily: failed API routes include a `debug` object in the JSON body
# (message/code) so you can see errors in the browser Network tab when CloudWatch is empty.
# DEBUG_API_ERRORS=1

# First-party analytics (S3 prefix analytics/session-meta/). Ingest requires =1.
# GET /api/analytics/summary and /metrics are public (no secret).
# Summary caches a single aggregate at analytics/metrics-aggregate.json (default TTL 8000 ms).
# ANALYTICS_SUMMARY_AGGREGATE_TTL_MS=8000
# ANALYTICS_SUMMARY_AGGREGATE_DISABLED=1
# NEXT_PUBLIC_ANALYTICS_ENABLED=1
# Optional pepper for hashing signed-in users in meta (recommended in production):
# ANALYTICS_USER_HASH_PEPPER=

# Optional comma-separated exact origins for verification links (overrides default allowlist)
# AUTH_ALLOWED_ORIGINS=https://arells.com,https://test.d1gnzirfh2jgi9.amplifyapp.com

# Growth / retention dashboard (GET /api/metrics/growth). If unset, the API is open (dev only).
# Send the same value as Authorization: Bearer <secret> or ?key= on /metrics after pasting in UI.
# METRICS_API_SECRET=
# METRICS_GROWTH_CACHE_TTL_MS=120000
# METRICS_GROWTH_CACHE_DISABLED=1
# Ignore analytics before this UTC calendar day (YYYY-MM-DD). Rolling 1W/1M/3M/1Y start no earlier than this.
# Default when unset: 2026-04-01. Until enough days exist after this date, longer presets behave like shorter ones.
# METRICS_EPOCH_START_UTC=2026-04-01

# Label path in DAU/WAU/MAU API response (mounts are recorded by POST /api/metrics/page-mount on /metrics).
# METRICS_ACTIVITY_PAGE_PATH=/metrics
# METRICS_PAGE_ACTIVITY_CACHE_TTL_MS=120000
# METRICS_PAGE_ACTIVITY_CACHE_DISABLED=1
