# Required on Amplify: Environment variables (per branch). Must be available during `yarn build` — next.config embeds
# S3_BUCKET_NAME, WS_REGION, WS_ACCESS_KEY_ID, WS_SECRET_ACCESS_KEY, VERIFY_EMAIL_FROM, PASSWORD_RESET_FROM, and
# AUTH_JWT_SECRET (min 16 chars) into server/API bundles when set (Amplify often omits custom vars at Lambda runtime).
# Do not use NEXT_PUBLIC_* for secrets.
# Prefer an IAM role on Amplify compute with S3/SES policy; then you can omit static keys if the role is attached.
S3_BUCKET_NAME=
# Optional aliases (same value); next.config resolves these at build time and still inlines as S3_BUCKET_NAME server-side:
# AWS_S3_BUCKET=
# S3_BUCKET=

# AWS region + keys for S3 (Vavity, auth user JSON) and SES (verification / password reset). Standard AWS_* names are
# accepted as fallbacks; next.config inlines WS_* from either prefix at build.
WS_REGION=
WS_ACCESS_KEY_ID=
WS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Auth (required for login / session cookies; min 16 characters)
AUTH_JWT_SECRET=

# Transactional email (AWS SES). Required for sending; optional while testing:
# AUTH_EMAIL_DISABLED=1 logs the verification/reset URL instead of sending.
VERIFY_EMAIL_FROM=verifyemail@arells.com
PASSWORD_RESET_FROM=resetpassword@arells.com
# Optional: override logo URL in auth emails (default is https://arells.com/ArellsIcoIcon.png)
# AUTH_EMAIL_LOGO_URL=https://example.com/logo.png
# AUTH_EMAIL_DISABLED=1

# Fallback when Origin header is missing (e.g. some server-side calls)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public site origin for Next metadataBase: absolute favicon/canonical/relative openGraph image URLs (no trailing slash).
# REQUIRED on each Amplify branch: set to that branch's https URL (e.g. https://test....amplifyapp.com).
# If this stays wrong, `<link rel="icon" href="https://arells.com/...">` while users visit *.amplifyapp.com
# breaks favicon handling in Chrome mobile (gray globe) even though desktop looks fine.
# Production: https://arells.com | Amplify preview: https://test.d1gnzirfh2jgi9.amplifyapp.com
NEXT_PUBLIC_IMAGE_URL=http://localhost:3000

# Optional but recommended for mobile: favicon URLs in <head> get ?v=... so Safari/Chrome refetch after each deploy.
# Mobile favicon caches are separate from normal page cache; "Clear website data" often does NOT clear them.
# Set at build to something unique per deploy, e.g. Amplify: tie to commit id or build number in the console.
NEXT_PUBLIC_ASSET_VERSION=

# Server-only: set to 1 on Amplify temporarily so 500 JSON responses include a `debug` object.
# The browser console will show that payload via [API] ... console.error (see logClientApiError).
# DEBUG_API_ERRORS=1

# First-party analytics (S3 prefix analytics/session-meta/). Ingest requires =1.
# GET /api/analytics/summary and /metrics are public (no secret).
# Summary caches a single aggregate at analytics/metrics-aggregate.json (default TTL 8000 ms).
# ANALYTICS_SUMMARY_AGGREGATE_TTL_MS=8000
# ANALYTICS_SUMMARY_AGGREGATE_DISABLED=1
# NEXT_PUBLIC_ANALYTICS_ENABLED=1
# Optional pepper for hashing signed-in users in meta (recommended in production):
# ANALYTICS_USER_HASH_PEPPER=

# Optional comma-separated exact origins for verification links (overrides default allowlist)
# AUTH_ALLOWED_ORIGINS=https://arells.com,https://test.d1gnzirfh2jgi9.amplifyapp.com

# Growth / retention dashboard (GET /api/metrics/growth). If unset, the API is open (dev only).
# Send the same value as Authorization: Bearer <secret> or ?key= on /metrics after pasting in UI.
# METRICS_API_SECRET=
# METRICS_GROWTH_CACHE_TTL_MS=120000
# METRICS_GROWTH_CACHE_DISABLED=1
# Ignore analytics before this UTC calendar day (YYYY-MM-DD). Rolling 1W/1M/3M/1Y start no earlier than this.
# Default when unset: 2026-04-01. Until enough days exist after this date, longer presets behave like shorter ones.
# METRICS_EPOCH_START_UTC=2026-04-01

# Label path in DAU/WAU/MAU API response (mounts are recorded by POST /api/metrics/page-mount on /metrics).
# METRICS_ACTIVITY_PAGE_PATH=/metrics
# METRICS_PAGE_ACTIVITY_CACHE_TTL_MS=120000
# METRICS_PAGE_ACTIVITY_CACHE_DISABLED=1
